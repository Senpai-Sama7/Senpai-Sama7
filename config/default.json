{
  "sparkline": {
    "width": 400,
    "height": 60,
    "margin": 10,
    "strokeWidth": 2,
    "pointRadius": 3,
    "colors": {
      "gradientStart": "#4facfe",
      "gradientEnd": "#00f2fe"
    },
    "opacity": 0.8,
    "animation": {
      "enabled": true,
      "duration": "8s"
    }
  },
  "radar": {
    "size": 200,
    "centerRadius": 0,
    "maxRadius": 70,
    "gridLevels": [20, 40, 60, 80, 100],
    "strokeWidth": 2,
    "fontSize": 10,
    "colors": {
      "grid": "#e1e5e9",
      "fill": "url(#radarGradient)",
      "stroke": "#4facfe",
      "text": "#586069",
      "gradientStart": "#4facfe",
      "gradientEnd": "#00f2fe"
    },
    "opacity": {
      "fill": 0.6,
      "grid": 0.5
    }
  },
  "github": {
    "api": {
      "baseUrl": "https://api.github.com",
      "timeout": 30000,
      "retries": 3,
      "retryDelay": 1000
    },
    "rateLimit": {
      "maxRequests": 5000,
      "windowMs": 3600000
    },
    "cache": {
      "enabled": true,
      "ttl": 300000,
      "maxSize": 100
    }
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": {
      "enabled": true,
      "path": "logs/",
      "maxSize": "10MB",
      "backupCount": 5
    },
    "console": {
      "enabled": true,
      "colorize": true
    }
  },
  "performance": {
    "monitoring": {
      "enabled": true,
      "sampleRate": 1.0,
      "slowThreshold": 1000
    },
    "caching": {
      "enabled": true,
      "strategy": "lru",
      "maxSize": 1000,
      "ttl": 3600
    },
    "optimization": {
      "svgMinification": true,
      "compression": true,
      "lazyLoading": true
    }
  },
  "security": {
    "inputValidation": {
      "enabled": true,
      "strict": true,
      "sanitization": true
    },
    "rateLimit": {
      "enabled": true,
      "maxRequests": 100,
      "windowMs": 900000
    },
    "headers": {
      "contentSecurityPolicy": true,
      "xssProtection": true,
      "noSniff": true
    }
  },
  "features": {
    "sparkline": {
      "enabled": true,
      "realTimeData": true,
      "fallbackData": true
    },
    "radar": {
      "enabled": true,
      "customSkills": true,
      "animations": true
    },
    "metrics": {
      "enabled": true,
      "comprehensive": true,
      "backup": true
    }
  },
  "deployment": {
    "environment": "production",
    "debug": false,
    "monitoring": {
      "healthCheck": true,
      "metrics": true,
      "alerts": true
    }
  }
}